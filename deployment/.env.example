# =============================================================================
# EduFlow AI Assistant - Production Environment Configuration
# =============================================================================
# Copy this file to .env and fill in actual values before deploying

# =============================================================================
# LLM Provider Configuration
# =============================================================================

# LLM provider: "openai" or "yandex"
LLM_PROVIDER=openai

# OpenAI API configuration
# Get key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key

# YandexGPT API configuration (alternative provider)
YANDEX_API_KEY=your-yandex-api-key
YANDEX_FOLDER_ID=your-yandex-folder-id

# OpenAI Embeddings API key (for RAG vector embeddings)
OPENAI_EMBEDDINGS_API_KEY=sk-your-embeddings-api-key


# =============================================================================
# Integrations
# =============================================================================

# Bitrix24 CRM webhook URL
# Format: https://your-domain.bitrix24.ru/rest/1/webhook-token/
BITRIX24_WEBHOOK_URL=https://your-domain.bitrix24.ru/rest/1/your-webhook-token/

# Bitrix24 webhook secret for request validation
BITRIX24_WEBHOOK_TOKEN=your-bitrix24-webhook-secret

# Wappi (Telegram/WhatsApp) integration
WAPPI_API_TOKEN=your-wappi-api-token
WAPPI_PROFILE_ID=your-wappi-profile-id

# Wappi webhook secret for request validation
WAPPI_WEBHOOK_TOKEN=your-wappi-webhook-secret


# =============================================================================
# Database Configuration
# =============================================================================

# PostgreSQL connection string
# Format: postgresql+asyncpg://user:password@host:port/dbname
# Docker Compose uses: postgresql+asyncpg://postgres:postgres@db:5432/ai_assistant_eduflow
POSTGRES_DSN=postgresql+asyncpg://postgres:postgres@db:5432/ai_assistant_eduflow

# PostgreSQL password (used by docker-compose)
POSTGRES_PASSWORD=postgres


# =============================================================================
# Application Configuration
# =============================================================================

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Log format: json or console
LOG_FORMAT=json

# Rate limiting: requests per minute per IP
RATE_LIMIT_PER_MINUTE=100


# =============================================================================
# Security Notes
# =============================================================================
#
# IMPORTANT:
# - NEVER commit .env file to version control
# - Store .env in a secure location on the production server
# - Use strong, unique values for all tokens and secrets
# - Rotate API keys regularly
# - Use environment variables for deployment, not hardcoded values
#
