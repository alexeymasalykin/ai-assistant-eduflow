# LLM Provider: "openai" or "yandex"
LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key

# YandexGPT (alternative LLM provider)
YANDEX_API_KEY=your-yandex-api-key
YANDEX_FOLDER_ID=your-yandex-folder-id

# Bitrix24 CRM
BITRIX24_WEBHOOK_URL=https://your-domain.bitrix24.ru/rest/1/your-webhook-token/

# Wappi (Telegram + MAX Messenger)
WAPPI_API_TOKEN=your-wappi-api-token
WAPPI_PROFILE_ID=your-wappi-telegram-profile-id
WAPPI_MAX_PROFILE_ID=your-wappi-max-profile-id

# Database
POSTGRES_DSN=postgresql://postgres:postgres@db:5432/eduflow

# Embeddings (OpenAI)
OPENAI_EMBEDDINGS_API_KEY=sk-your-embeddings-api-key

# Security
WAPPI_WEBHOOK_TOKEN=your-wappi-webhook-secret
BITRIX24_WEBHOOK_TOKEN=your-bitrix24-webhook-secret
ADMIN_API_KEY=your-admin-api-key

# Rate limiting
RATE_LIMIT_PER_MINUTE=100

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Pipeline mode: "original" or "langchain"
PIPELINE_MODE=original

# Langfuse observability (optional)
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=pk-your-langfuse-public-key
LANGFUSE_SECRET_KEY=sk-your-langfuse-secret-key
LANGFUSE_HOST=https://cloud.langfuse.com
